raw_data = {
"username": "user1",
"password hash": "...",
"email": "user@example.com",
"location": "GPS COORDINATES", 
"age": 25 

}

def minimize_data(data):
    minimized = {k: v for k, v in data.items() if k in ["username", "email", "age"]}
    return minimized

minimized_data = minimize_data(raw_data)
print(minimized_data)
